# ==========================================================
# Шаблон конфигурации. Скопируйте в .env и заполните:
#   cp .env.example .env
# Файл .env в .gitignore и НЕ попадает в репозиторий.
# ==========================================================

# --- Telegram ---
# Токен от @BotFather (команда /newbot).
TELEGRAM_BOT_TOKEN=

# Белый список чатов через запятую: бот работает только в них.
# ID узнать: добавьте бота в группу и отправьте /chatid (у групп он отрицательный).
# Пусто = бот отвечает в любом чате, куда его добавили. Заполните это.
ALLOWED_CHAT_IDS=

# --- Anthropic (Claude API) ---
# Ключ из https://console.anthropic.com/ -> API keys. Начинается с sk-ant-
ANTHROPIC_API_KEY=

# Модель для ответов на вопросы и рецептов.
CLAUDE_MODEL=claude-opus-4-8
# Модель для разбора сообщений о покупках — самый частый вызов.
# Если пусто, используется CLAUDE_MODEL. Дешевле: claude-haiku-4-5
CLAUDE_PARSER_MODEL=

# Модель для чтения фото чеков. Если пусто, используется CLAUDE_MODEL.
# Экономить тут не советую: ошибка в распознавании мелкого шрифта дороже
# разницы в цене, а чеки приходят редко.
CLAUDE_VISION_MODEL=

# --- Поведение ---
# Символ валюты в отчётах.
CURRENCY=₽
# Часовой пояс (IANA), от него зависят «сегодня» и границы месяца.
TIMEZONE=Europe/Moscow
# Сколько дней продукт считается «лежит в холодильнике».
FRIDGE_WINDOW_DAYS=10
# Сколько последних покупок отдавать модели как контекст для вопросов.
CONTEXT_PURCHASES_LIMIT=150
# Как подтверждать запись покупки: reply (текстом) | reaction (эмодзи 👍) | quiet
CONFIRM_MODE=reply
# Читать ли фотографии чеков. false — бот будет игнорировать картинки.
READ_RECEIPTS=true
# Предел размера входящей картинки, МБ (потолок Telegram Bot API — 20 МБ).
MAX_IMAGE_MB=20

# --- Прочее ---
# Путь к файлу базы. По умолчанию data/bot.sqlite3 рядом с проектом.
DB_PATH=
# DEBUG | INFO | WARNING
LOG_LEVEL=INFO
