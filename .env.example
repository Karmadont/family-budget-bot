# ==========================================================
# Шаблон конфигурации. Скопируйте в .env и заполните:
#   cp .env.example .env
# Файл .env в .gitignore и НЕ попадает в репозиторий.
# ==========================================================

# --- Telegram ---
# Токен от @BotFather (команда /newbot).
TELEGRAM_BOT_TOKEN=

# Белый список чатов через запятую: бот работает только в них.
# ID узнать: добавьте бота в группу и отправьте /chatid (у групп он отрицательный).
# Пусто = бот отвечает в любом чате, куда его добавили. Заполните это.
ALLOWED_CHAT_IDS=

# --- Yandex Cloud (YandexGPT) ---
# API-ключ сервисного аккаунта с ролью ai.languageModels.user
# (плюс ai.vision.user, если будете разбирать чеки командой /receipt).
YANDEX_API_KEY=
# Идентификатор каталога из адресной строки консоли Yandex Cloud.
YANDEX_FOLDER_ID=

# Модель для вопросов и еженедельного анализа.
# Дешевле: yandexgpt-lite/latest
YANDEX_MODEL=yandexgpt/latest
# Модель для разбора коротких сообщений о покупках — самый частый вызов.
# По умолчанию lite: задача простая, старшая модель тут не нужна.
YANDEX_PARSER_MODEL=yandexgpt-lite/latest
# Модель, которая разбирает распознанный текст чека. Пусто = YANDEX_MODEL.
YANDEX_VISION_MODEL=
# Модель распознавания Yandex Vision OCR: page (обычный текст) | handwritten
YANDEX_OCR_MODEL=page
# Таймаут запроса к Yandex Cloud, секунд.
LLM_TIMEOUT=120

# --- Еженедельный дайджест (главная функция) ---
# Раз в неделю бот сам присылает разбор трат за прошлую неделю.
WEEKLY_DIGEST=true
# День публикации: 0 — понедельник, 1 — вторник … 6 — воскресенье.
WEEKLY_DIGEST_WEEKDAY=0
# Время публикации по TIMEZONE, ЧЧ:ММ.
WEEKLY_DIGEST_TIME=10:00
# Добавлять ли к цифрам короткий анализ от нейросети (тренд, что необычно).
# false — только таблица по категориям, без вызова модели.
WEEKLY_DIGEST_ANALYSIS=true

# --- Цены (для /cost) ---
# Прайс Яндекса зависит от тарифа и объёма, публичный прайс лишь ориентир.
# Впишите свои реальные ставки, иначе /cost покажет оценку, а не факт.
# Рублей за миллион токенов:
YANDEX_PRICE_LITE=200
YANDEX_PRICE_PRO=1200
# Рублей за одну распознанную страницу Yandex Vision OCR:
YANDEX_OCR_PRICE_PER_PAGE=0.26

# --- Поведение ---
# Символ валюты в отчётах о покупках.
CURRENCY=₽
# Часовой пояс (IANA), от него зависят «сегодня», границы недели и время дайджеста.
TIMEZONE=Europe/Moscow
# Сколько дней продукт считается «лежит в холодильнике» (для /fridge и /recipe).
FRIDGE_WINDOW_DAYS=10
# Сколько последних покупок отдавать модели как контекст для вопросов.
CONTEXT_PURCHASES_LIMIT=150
# Как подтверждать запись покупки: reply (текстом) | reaction (эмодзи 👍) | quiet
CONFIRM_MODE=reply
# Разрешён ли разбор фото чеков командой /receipt. false — команда откажет.
READ_RECEIPTS=true
# Предел размера фото чека, МБ (потолок Telegram Bot API — 20 МБ).
MAX_IMAGE_MB=20

# --- Прочее ---
# Путь к файлу базы. По умолчанию data/bot.sqlite3 рядом с проектом.
DB_PATH=
# DEBUG | INFO | WARNING
LOG_LEVEL=INFO
