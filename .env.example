# ==========================================================
# Шаблон конфигурации. Скопируйте в .env и заполните:
#   cp .env.example .env
# Файл .env в .gitignore и НЕ попадает в репозиторий.
# ==========================================================

# --- Telegram ---
# Токен от @BotFather (команда /newbot).
TELEGRAM_BOT_TOKEN=

# Белый список чатов через запятую: бот работает только в них.
# ID узнать: добавьте бота в группу и отправьте /chatid (у групп он отрицательный).
# Пусто = бот отвечает в любом чате, куда его добавили. Заполните это.
ALLOWED_CHAT_IDS=

# ==========================================================
# Какая нейросеть работает
# ==========================================================
# claude | yandexgpt | gigachat — кто разбирает сообщения и отвечает на вопросы.
LLM_PROVIDER=claude

# Кто читает фото чеков. Пусто = тот же, что и LLM_PROVIDER.
# Вынесено отдельно, потому что зрение — самое слабое место у российских
# моделей: можно гонять чат через GigaChat, а чеки оставить на Claude.
VISION_PROVIDER=

# Ключи нужны только от включённых провайдеров: если LLM_PROVIDER=gigachat
# и VISION_PROVIDER=gigachat, ANTHROPIC_API_KEY можно оставить пустым.

# --- Anthropic (Claude API) ---
# Ключ из https://console.anthropic.com/ -> API keys. Начинается с sk-ant-
ANTHROPIC_API_KEY=

# Модель для ответов на вопросы и рецептов.
CLAUDE_MODEL=claude-opus-4-8
# Модель для разбора сообщений о покупках — самый частый вызов.
# Если пусто, используется CLAUDE_MODEL. Дешевле: claude-haiku-4-5
CLAUDE_PARSER_MODEL=

# Модель для чтения фото чеков. Если пусто, используется CLAUDE_MODEL.
# Экономить тут не советую: ошибка в распознавании мелкого шрифта дороже
# разницы в цене, а чеки приходят редко.
CLAUDE_VISION_MODEL=

# --- Yandex Cloud (YandexGPT) ---
# API-ключ сервисного аккаунта с ролью ai.languageModels.user
# (плюс ai.vision.user, если этот провайдер будет читать чеки).
YANDEX_API_KEY=
# Идентификатор каталога из адресной строки консоли Yandex Cloud.
YANDEX_FOLDER_ID=

# Модель с версией, подставляется в modelUri: gpt://<folder>/<model>
# Дешевле: yandexgpt-lite/latest
YANDEX_MODEL=yandexgpt/latest
# Модель для разбора покупок. Пусто = YANDEX_MODEL.
YANDEX_PARSER_MODEL=
# Модель, которая разбирает распознанный текст чека. Пусто = YANDEX_MODEL.
YANDEX_VISION_MODEL=
# Модель распознавания Yandex Vision OCR: page (обычный текст) | handwritten
YANDEX_OCR_MODEL=page

# --- Сбер (GigaChat) ---
# Ключ авторизации из личного кабинета — длинная строка base64, копируется целиком.
GIGACHAT_AUTH_KEY=
# GIGACHAT_API_PERS (физлица) | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# GigaChat-2-Max | GigaChat-2-Pro | GigaChat-2 (Lite, дешевле всего)
GIGACHAT_MODEL=GigaChat-2-Max
# Модель для разбора покупок. Пусто = GIGACHAT_MODEL.
GIGACHAT_PARSER_MODEL=
# Модель для чеков. Пусто = GIGACHAT_MODEL. Lite картинок не видит.
GIGACHAT_VISION_MODEL=

# Сертификат GigaChat подписан НУЦ Минцифры. Скачайте корневой сертификат
# (https://www.gosuslugi.ru/crt) и укажите путь к .pem здесь.
GIGACHAT_CA_BUNDLE=
# Аварийный выключатель проверки TLS. false — соединение никто не проверяет,
# используйте, только если сертификат установить совсем не выходит.
GIGACHAT_VERIFY_SSL=true

# ==========================================================
# Цены (для /cost)
# ==========================================================
# Курс доллара. Нужен, чтобы показать расход на Claude в рублях и сравнить
# его с YandexGPT/GigaChat в одной валюте. Пусто или 0 — не сводить.
USD_RATE=

# Прайс Anthropic зашит в usage.py. У Яндекса и Сбера цена зависит от тарифа,
# поэтому здесь стоят ориентировочные значения — впишите свои реальные ставки,
# иначе /cost покажет оценку, а не факт.
# Рублей за миллион токенов:
YANDEX_PRICE_LITE=200
YANDEX_PRICE_PRO=1200
GIGACHAT_PRICE_LITE=200
GIGACHAT_PRICE_PRO=1500
GIGACHAT_PRICE_MAX=1950
# Рублей за одну распознанную страницу Yandex Vision OCR:
YANDEX_OCR_PRICE_PER_PAGE=0.26

# ==========================================================
# Поведение
# ==========================================================
# Символ валюты в отчётах о покупках.
CURRENCY=₽
# Часовой пояс (IANA), от него зависят «сегодня» и границы месяца.
TIMEZONE=Europe/Moscow
# Сколько дней продукт считается «лежит в холодильнике».
FRIDGE_WINDOW_DAYS=10
# Сколько последних покупок отдавать модели как контекст для вопросов.
CONTEXT_PURCHASES_LIMIT=150
# Как подтверждать запись покупки: reply (текстом) | reaction (эмодзи 👍) | quiet
CONFIRM_MODE=reply
# Читать ли фотографии чеков. false — бот будет игнорировать картинки.
READ_RECEIPTS=true
# Предел размера входящей картинки, МБ (потолок Telegram Bot API — 20 МБ).
MAX_IMAGE_MB=20
# Таймаут запроса к YandexGPT/GigaChat, секунд.
LLM_TIMEOUT=120

# --- Прочее ---
# Путь к файлу базы. По умолчанию data/bot.sqlite3 рядом с проектом.
DB_PATH=
# DEBUG | INFO | WARNING
LOG_LEVEL=INFO
